{
  "name": "nomokit-desktop",
  "version": "3.0.0",
  "main": "main.js",
  "scripts": {
    "test": "node test/run-tests.js && node test/e2e/e2e-test-matrix.js",
    "fetch:driver": "rimraf tools firmwares && node src/link/script/download-tools.js && node src/link/script/download-firmwares.js",
    "start": "electron .",
    "test:smoke": "node test/run-tests.js",
    "test:e2e": "node test/e2e/e2e-test-matrix.js",
    "postinstall": "electron-rebuild -f -w @abandonware/noble",
    "check-bundled-python": "node test/smoke/check_bundled_python.js",
    "install-python-payload": "node scripts/install_python_payload.js",
    "clean:tools": "rimraf \"src/link/tools/Arduino/staging\" \"src/link/tools/Arduino/tmp\"",
    "clean:native": "rimraf \"node_modules/@abandonware/noble/build\"",
    "prebuild": "npm run clean:tools && npm run prebuild:avr",
    "prebuild:avr": "node -e \"var y=require('js-yaml'),fs=require('fs'),p=require('path'),cfg=y.load(fs.readFileSync('src/link/tools/Arduino/arduino-cli.yaml','utf8'));var dir=cfg.directories.data,avrDir=p.join(dir,'packages/arduino/hardware/avr');if(!fs.existsSync(avrDir)){require('child_process').execSync('arduino-cli core install arduino:avr --config-file arduino-cli.yaml',{cwd:'src/link/tools/Arduino',stdio:'inherit'})}\"",
    "build": "npm run prebuild && electron-builder --win",
    "build:mac": "npm run prebuild && electron-builder --mac",
    "deploy:all": "npm run prebuild && electron-builder --mac --win -p always",
    "deploy:mac": "npm run prebuild && electron-builder --mac -p always",
    "deploy:win": "npm run prebuild && electron-builder --win -p always"
  },
  "description": "Nomokit Desktop App",
  "repository": "https://github.com/Xart22/nomopro-desktop",
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "build": {
    "appId": "com.nomokit.desktop",
    "productName": "nomokit-Desktop",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "**/*",
      "!python",
      "!src/link/tools/Arduino/staging",
      "!src/link/tools/Arduino/tmp",
      "!src/link/tools/Arduino/packages",
      "!src/gui/**/*.map",
      "!test",
      "data/*.json*"
    ],
    "win": {
      "publish": [
        "github"
      ],
      "target": [
        "nsis"
      ],
      "icon": "src/assets/img/nomokit.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "category": "public.app-category.education",
      "entitlements": "build/entitlements.mac.plist",
      "gatekeeperAssess": true,
      "hardenedRuntime": true,
      "icon": "src/assets/img/512.png",
      "provisioningProfile": "embedded.provisionprofile",
      "publish": [
        "github"
      ],
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "nsis": {
      "artifactName": "Nomokit-Desktop-${version}.${ext}",
      "oneClick": true,
      "uninstallDisplayName": "Nomokit-Desktop-uninstaller",
      "installerIcon": "src/assets/img/nomokit.ico",
      "shortcutName": "Nomokit-Desktop",
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "include": "build/installer.nsh"
    },
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/nomokitjr",
        "to": "nomokitjr",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "author": "Sonasoft",
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@serialport/bindings-cpp": "^13.0.1",
    "adm-zip": "^0.5.17",
    "ansi-string": "^0.2.1",
    "axios": "^1.16.1",
    "bootstrap": "^5.3.8",
    "cli-color": "^2.0.4",
    "compare-versions": "^6.1.1",
    "download-github-release": "^0.3.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "folder-hash": "^4.1.2",
    "format-message": "^6.2.4",
    "fs-extra": "^11.3.5",
    "hash-files": "^1.1.1",
    "js-yaml": "^4.1.1",
    "laravel-echo": "^2.3.4",
    "lodash": "^4.18.1",
    "node-abort-controller": "^3.1.1",
    "node-fetch": "^3.3.2",
    "node-fetch-progress": "^1.0.2",
    "node-machine-id": "^1.1.12",
    "nodejs-file-downloader": "^4.13.0",
    "openblock-parse-release-message": "0.0.4",
    "proper-lockfile": "^4.1.2",
    "pusher-js": "^8.5.0",
    "require-all": "^3.0.0",
    "serialport": "^13.0.0",
    "socket.io-client": "^4.8.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "babel-eslint": "^10.1.0",
    "copy-dir": "^1.3.0",
    "electron": "^42.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^10.4.0",
    "jsdoc": "^4.0.5",
    "openblock-resource-cli": "^0.2.5",
    "progress": "^2.0.3",
    "rimraf": "^6.1.3",
    "transifex": "^1.6.6"
  }
}
